# Enables Narakeet Khmer API voices:
# - khmer-male-graham
# - khmer-male-sovath
# - khmer-female-nisa
NARAKEET_API_KEY=

# Enables tool short links through Vercel KV / Upstash Redis.
# Used by PayBack Calculator and Expense Tracker sharing.
# These values are server-only and must not be exposed with a public prefix.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional aliases if the database is connected outside Vercel KV naming.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Enables confirmed Expense Tracker saves through the separate NestJS API.
# Use the dev API URL for Vercel Preview, and the production API URL for Vercel Production.
NUXT_PUBLIC_EXPENSE_TRACKER_API_BASE_URL=http://localhost:4001/api
NUXT_PUBLIC_TELEGRAM_BOT_USERNAME=
