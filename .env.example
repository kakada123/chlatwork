# Enables Narakeet Khmer API voices:
# - khmer-male-graham
# - khmer-male-sovath
# - khmer-female-nisa
NARAKEET_API_KEY=

# Enables PayBack Calculator short links through Vercel KV / Upstash Redis.
# These values are server-only and must not be exposed with a public prefix.
KV_REST_API_URL=
KV_REST_API_TOKEN=

