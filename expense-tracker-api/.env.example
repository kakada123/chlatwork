APP_PORT=4001
NODE_ENV=development

# Comma-separated frontend origins allowed to call this API.
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Auth token signing.
AUTH_TOKEN_SECRET=change-this-local-secret
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_COOKIE_NAME=chlatwork_expense_auth
AUTH_COOKIE_PATH=/api
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# Telegram Login Widget. Use BotFather to create a bot and configure the domain.
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# MySQL/MariaDB database for confirmed Expense Tracker saves.
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=chlatwork

# Keep false in production. Set true only for local first-run table creation.
DB_SYNC=false
DB_LOGGING=false
